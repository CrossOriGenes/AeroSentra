<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="18dp"
    android:translationY="-100dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="true"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/current_weather_card_2"
        tools:ignore="UnknownIdInLayout">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="5dp"
            android:layout_weight="1"
            android:background="@drawable/card_gradient_bg_dark"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="15dp">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="-8dp"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="@string/weather_today_item_8"
                    android:src="@drawable/ic_wind_propeller"
                    app:tint="#92B6B6" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="4dp"
                        android:fontFamily="@font/jost_semibold"
                        android:text="@string/weather_today_item_8"
                        android:textAllCaps="true"
                        android:textColor="#92B6B6"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/wind_direction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="0dp"
                            android:layout_marginEnd="6dp"
                            android:fontFamily="@font/jost_bold"
                            android:textColor="@color/white"
                            android:textSize="22sp" />

                        <ImageView
                            android:id="@+id/wind_direction_icon"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:contentDescription="@string/weather_today_item_8"
                            android:src="@drawable/ic_navigation_direct"
                            app:tint="#0ff" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="5dp"
            android:layout_marginEnd="0dp"
            android:layout_weight="1"
            android:background="@drawable/card_gradient_bg_dark"
            android:elevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="15dp">

                <ImageView
                    android:layout_width="45dp"
                    android:layout_height="45dp"
                    android:layout_marginStart="-8dp"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="@string/weather_today_item_8"
                    android:src="@drawable/ic_eco"
                    app:tint="#92B6B6" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:gravity="center_vertical"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:text="@string/weather_today_item_9"
                        android:textAllCaps="true"
                        android:textColor="#92B6B6"
                        android:textSize="13sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/aqi_val"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="0dp"
                            android:layout_marginEnd="6dp"
                            android:fontFamily="@font/jost_bold"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/aqi_icon"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:contentDescription="@string/weather_today_item_9"
                            android:src="@drawable/rounded_pill" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

        </FrameLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>