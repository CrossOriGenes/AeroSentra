<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/current_weather_card_1"
    android:layout_height="match_parent"
    android:layout_width="match_parent">

    <FrameLayout
        android:id="@+id/weather_card"
        android:layout_width="0dp"
        android:layout_height="510dp"
        android:layout_marginTop="17dp"
        android:background="@drawable/weather_image_card_bg"
        android:elevation="0dp"
        android:clipToOutline="true"
        app:layout_constraintTop_toBottomOf="@+id/dashboard_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        tools:ignore="UnknownIdInLayout">
        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/app_name"
            android:scaleType="centerCrop"
            android:src="@drawable/app_bg_3" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/temperature_value"
                android:layout_width="match_parent"
                android:layout_height="135dp"
                android:fontFamily="@font/jost_bold"
                android:paddingStart="30dp"
                android:paddingEnd="0dp"
                android:textColor="@color/white"
                android:textSize="105sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="26dp"
                android:layout_marginTop="-10dp">

                <ImageView
                    android:id="@+id/weather_now_icon"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    app:tint="#666" />

                <TextView
                    android:id="@+id/weather_now_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="6dp"
                    android:fontFamily="@font/jost_semibold"
                    android:textColor="#878686"
                    android:textSize="22sp" />

            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <FrameLayout
        android:id="@+id/weather_today_card"
        android:layout_width="0dp"
        android:layout_height="190dp"
        android:layout_marginHorizontal="6dp"
        android:background="@drawable/card_glass_bg"
        android:elevation="8dp"
        android:translationY="-135dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/weather_card">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:fontFamily="@font/jost_extrabold"
                android:gravity="center"
                android:paddingTop="0dp"
                android:paddingBottom="10dp"
                android:text="@string/weather_today_title"
                android:textColor="#333"
                android:textSize="18.5sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4"
                android:layout_marginTop="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_marginBottom="5dp"
                        android:src="@drawable/ic_temp_high"
                        app:tint="#FF0048"
                        android:contentDescription="@string/weather_today_item_1"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:paddingTop="4dp"
                        android:paddingBottom="1dp"
                        android:textAllCaps="true"
                        android:text="@string/weather_today_item_1"
                        android:textColor="#646363"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/maxTemp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_marginBottom="5dp"
                        android:src="@drawable/ic_temp_low"
                        app:tint="#005EFF"
                        android:contentDescription="@string/weather_today_item_2" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:paddingTop="4dp"
                        android:paddingBottom="1dp"
                        android:textAllCaps="true"
                        android:text="@string/weather_today_item_2"
                        android:textColor="#646363"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/minTemp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_marginBottom="5dp"
                        android:src="@drawable/ic_feels_like"
                        app:tint="#FF6600"
                        android:contentDescription="@string/weather_today_item_3" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:paddingTop="4dp"
                        android:paddingBottom="1dp"
                        android:textAllCaps="true"
                        android:text="@string/weather_today_item_3"
                        android:textColor="#646363"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/feelsLike"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:textSize="28sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_marginBottom="5dp"
                        android:src="@drawable/ic_drops"
                        app:tint="#341B66"
                        android:contentDescription="@string/weather_today_item_4" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:paddingTop="4dp"
                        android:paddingBottom="1dp"
                        android:textAllCaps="true"
                        android:text="@string/weather_today_item_4"
                        android:textColor="#646363"
                        android:textSize="11sp" />

                    <TextView
                        android:id="@+id/precipPercent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/jost_semibold"
                        android:gravity="center"
                        android:textColor="@color/black"
                        android:textSize="28sp" />
                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>