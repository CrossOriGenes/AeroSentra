<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/card_gradient_bg"
    android:backgroundTint="#021F1F"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="20dp"
    android:paddingTop="10dp"
    android:paddingEnd="20dp"
    android:paddingBottom="10dp">
    <TextView
        android:id="@+id/cityNameInfoWindow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jost_medium"
        android:gravity="center"
        android:textColor="@color/white"
        android:textSize="15sp" />
    <ImageView
        android:id="@+id/weatherIconInfoWindow"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_marginTop="2.5dp"
        android:layout_marginBottom="2.5dp"
        android:contentDescription="@string/activity_title" />
    <TextView
        android:id="@+id/temperatureInfoWindow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/jost_bold"
        android:gravity="center"
        android:textColor="#E0FFFF"
        android:textSize="20sp" />
</LinearLayout>