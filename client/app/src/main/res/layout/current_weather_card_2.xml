<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/current_weather_card_2"
    android:layout_width="match_parent"
    android:layout_height="150dp"
    android:elevation="4dp"
    android:translationY="-120dp"
    android:layout_marginHorizontal="18dp"
    android:background="@drawable/card_gradient_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center|center_vertical"
            android:orientation="horizontal"
            android:padding="20dp"
            android:weightSum="3">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="0dp"
                android:layout_marginEnd="10dp"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/weather_today_item_5"
                    android:src="@drawable/ic_wind"
                    app:tint="#7AA6A6" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_semibold"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:text="@string/weather_today_item_5"
                    android:textAllCaps="true"
                    android:textColor="#959494"
                    android:textSize="13.5sp" />

                <TextView
                    android:id="@+id/wind_speed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_bold"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:textColor="@color/white"
                    android:textSize="19sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#B18C8C8C" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/weather_today_item_6"
                    android:src="@drawable/ic_pressure"
                    app:tint="#7AA6A6" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_semibold"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:text="@string/weather_today_item_6"
                    android:textAllCaps="true"
                    android:textColor="#959494"
                    android:textSize="13.5sp" />

                <TextView
                    android:id="@+id/pressure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_bold"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:textColor="@color/white"
                    android:textSize="19sp" />
            </LinearLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="#B18C8C8C" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingStart="8dp"
                android:paddingEnd="0dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="@string/weather_today_item_7"
                    android:src="@drawable/ic_humidity"
                    app:tint="#7AA6A6" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_semibold"
                    android:gravity="center"
                    android:paddingTop="4dp"
                    android:text="@string/weather_today_item_7"
                    android:textAllCaps="true"
                    android:textColor="#959494"
                    android:textSize="13.5sp" />

                <TextView
                    android:id="@+id/humidity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/jost_bold"
                    android:gravity="center"
                    android:paddingTop="8dp"
                    android:textColor="@color/white"
                    android:textSize="21sp" />
            </LinearLayout>
        </LinearLayout>
</FrameLayout>

